    },
    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"risk_level\": {\n      \"type\": \"string\",\n      \"enum\": [\"PROCEED\", \"MANUAL_REVIEW\", \"BLOCK\"]\n    },\n    \"decision\": {\n      \"type\": \"string\"\n    },\n    \"summary\": {\n      \"type\": \"string\"\n    },\n    \"top_risks\": {\n      \"type\": \"array\",\n      \"items\": { \"type\": \"string\" }\n    },\n    \"recommended_actions\": {\n      \"type\": \"array\",\n      \"items\": { \"type\": \"string\" }\n    },\n    \"evidence\": {\n      \"type\": \"object\",\n      \"additionalProperties\": true\n    }\n  },\n  \"required\": [\n    \"risk_level\",\n    \"decision\",\n    \"summary\",\n    \"top_risks\",\n    \"recommended_actions\",\n    \"evidence\"\n  ]\n}",
        "autoFix": true
      },
