        "jsCode": "const out = [];\n// Run-ID vom alten Code-Knoten holen:\nconst runId = $('Code - Merge Run Context').first().json.run_id;\n\n// DIE WICHTIGE ÄNDERUNG: Die KI-Daten direkt vom Agenten-Knoten abgreifen\n// anstatt das \"$json\" der Datenbank-Antwort zu benutzen!\nconst agent = $('AI Agent').first().json; \n\nfor (const risk of (agent.top_risks || [])) {\n  out.push({\n    json: {\n      run_id: runId,\n      finding_type: 'risk',\n      severity: agent.risk_level === 'BLOCK'\n        ? 'HIGH'\n        : agent.risk_level === 'MANUAL_REVIEW'\n          ? 'MEDIUM'\n          : 'LOW',\n      finding_key: null,\n      finding_value: risk,\n      details: {}\n    }\n  });\n}\n\nreturn out;\n\n"
