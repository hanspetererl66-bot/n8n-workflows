    {
      "parameters": {
        "jsCode": "const report = $json.dependency_report || {};\n\nconst asString = (arr) => (Array.isArray(arr) ? arr.join('\\n').toLowerCase() : '');\nconst modules = asString(report.loaded_modules_raw);\nconst dkms = asString(report.dkms_modules);\nconst dbs = asString(report.database_processes);\nconst containers = asString(report.container_processes);\nconst agents = asString(report.agent_processes);\nconst multipath = asString(report.multipath_raw);\nconst failedServices = asString(report.failed_services);\nconst journal = asString(report.journal_errors);\n\nconst flags = [];\n\nif (dkms.includes('nvidia')) flags.push({severity: 'HIGH', key: 'dkms_nvidia', message: 'NVIDIA DKMS module detected'});\nif (dkms.trim().length > 0) flags.push({severity: 'MEDIUM', key: 'dkms_present', message: 'DKMS modules present'});\nif (multipath.includes('dm_multipath') || modules.includes('dm_multipath')) flags.push({severity: 'HIGH', key: 'multipath', message: 'Multipath detected'});\nif (dbs.includes('oracle')) flags.push({severity: 'HIGH', key: 'oracle', message: 'Oracle process detected'});\nif (dbs.includes('postgres')) flags.push({severity: 'MEDIUM', key: 'postgresql', message: 'PostgreSQL process detected'});\nif (dbs.includes('hdb')) flags.push({severity: 'HIGH', key: 'hana', message: 'SAP HANA process detected'});\nif (containers.includes('kubelet')) flags.push({severity: 'HIGH', key: 'kubelet', message: 'Kubernetes node components detected'});\nif (containers.includes('dockerd') || containers.includes('containerd')) flags.push({severity: 'MEDIUM', key: 'containers', message: 'Container runtime detected'});\nif (agents.includes('falcon') || agents.includes('crowdstrike')) flags.push({severity: 'HIGH', key: 'falcon', message: 'Falcon/CrowdStrike agent detected'});\nif (failedServices.trim().length > 0) flags.push({severity: 'HIGH', key: 'failed_services', message: 'There are failed services before upgrade'});\nif (journal.trim().length > 0) flags.push({severity: 'MEDIUM', key: 'journal_errors', message: 'Kernel or system errors exist in current boot log'});\n\nlet baseRisk = 'LOW';\nif (flags.some(f => f.severity === 'HIGH')) baseRisk = 'MANUAL_REVIEW';\nif (flags.filter(f => f.severity === 'HIGH').length >= 2) baseRisk = 'BLOCK';\n\nreturn [{\n  json: {\n    ...$json,\n    deterministic_assessment: {\n      base_risk: baseRisk,\n      flags\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
