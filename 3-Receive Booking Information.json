    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE downtime_requests \nSET downtime_start = $1::timestamp, \n    downtime_end = $2::timestamp, \n    timezone = $3, \n    comments = NULLIF($4, 'no comment'), \n    request_status = 'BOOKED' \nWHERE booking_token = $5;\n\n",
        "options": {
          "queryReplacement": "={{ $json.downtime_start }},{{ $json.downtime_end }},{{ $json.timezone }},{{ $json.comments || 'no comment' }},{{ $json.booking_token }}"
        }
      },
