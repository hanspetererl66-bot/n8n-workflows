      "id": "0ec52662-1141-46ff-b962-7dc89f7633d7",
      "name": "Update Downtime request",
      "credentials": {
        "postgres": {
          "id": "2Oz45cpvd71nQQ1K",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const startRaw = $json.downtime_start;\nconst endRaw = $json.downtime_end;\n\n// Wir wandeln es sicherheitshalber in Text um, um es in der Fehlermeldung anzuzeigen\nconst startStr = String(startRaw);\nconst endStr = String(endRaw);\n\nconst start = new Date(startRaw);\nconst end = new Date(endRaw);\n\n// Wenn aus dem Input keine echte Zeit berechnet werden kann:\nif (isNaN(start.getTime()) || isNaN(end.getTime())) {\n  // DIE NEUE FEHLERMELDUNG ZEIGT DEN ECHTEN INHALT:\n  throw new Error(`Fehler bei der Zeitberechnung! Ich habe folgendes empfangen: Start=\"${startStr}\" und Ende=\"${endStr}\". (Tipp: Wenn hier ein n8n-Code wie {{ $json... }} steht, hast du im Set-Node vergessen, auf das Zahnrad für \"Expression\" zu klicken!)`);\n}\n\n// 12 Stunden für Precheck abziehen\nconst precheck = new Date(start);\nprecheck.setHours(precheck.getHours() - 12);\n\n// Dauer in Minuten berechnen\nconst durationMinutes = Math.round((end.getTime() - start.getTime()) / 60000);\n\n// Ausgabe\nreturn [{\n  json: {\n    ...$json,\n    precheck_planned_at: precheck.toISOString(),\n    maintenance_window_start: startRaw,\n    maintenance_window_end: endRaw,\n    window_duration_minutes: durationMinutes\n  }\n}];\n"
      },
      "id": "cb8189d3-3be9-4ce0-8579-ddc7b8c70713",
      "name": "Calculate Precheck",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        -400
      ]
    }
